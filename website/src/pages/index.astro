      const STATUS_HINTS: Record<string, () => string> = {
        main: () => mainHint(),
        git: () => 'the git tab: click the sections — commits · flow · branches · PRs',
        orch: () => 'the orchestration board — click a task to select it',
      };
      let activeTab = 'main';

      function setStatusHint() {
        const note = $('status-note');
        if (note) note.textContent = STATUS_HINTS[activeTab]();
      }
      function showGit(section: string) {
        const body = $('gbody');
        if (body) body.innerHTML = GIT_VIEWS[section];
        document.querySelectorAll('.gtab').forEach((t) =>
          t.classList.toggle('on', t.getAttribute('data-g') === section)
        );
      }
      function renderOrch(selected: number) {
        const body = $('obody');
        if (!body) return;
        body.innerHTML = ORCH_ROWS.map(
          (r, i) => `<button class="grow orow ${i === selected ? 'sel' : ''}" data-row="${i}">${r}</button>`
        ).join('');
        body.querySelectorAll('.orow').forEach((r) =>
          r.addEventListener('click', () => renderOrch(Number(r.getAttribute('data-row'))))
        );
      }
      function switchTab(tab: string) {
        activeTab = tab;
        ['main', 'git', 'orch'].forEach((t) => {
          const v = $(`view-${t}`);
          if (v) (v as HTMLElement).hidden = t !== tab;
        });
        document.querySelectorAll('.demo-tabs .tab[data-tab]').forEach((t) =>
          t.classList.toggle('on', t.getAttribute('data-tab') === tab)
        );
        setStatusHint();
      }
      document.querySelectorAll('.demo-tabs .tab[data-tab]').forEach((t) =>
        t.addEventListener('click', () => switchTab(t.getAttribute('data-tab') ?? 'main'))
      );
      document.querySelectorAll('.gtab').forEach((t) =>
        t.addEventListener('click', () => showGit(t.getAttribute('data-g') ?? 'commits'))
      );

      if ($('demo')) {
        CODEX_DONE.forEach((l) => push('codex-body', l));
        renderCopilot();
        focusAgent('claude');
        claudeTick();
        showGit('commits');
        renderOrch(1);
        setStatusHint();
        // Deep-linkable demo state: /?demo=git or /?demo=orch opens that tab.
        const deep = new URLSearchParams(location.search).get('demo');
        if (deep === 'git' || deep === 'orch') switchTab(deep);
      }

      // Copy the install one-liner.
      const btn = document.getElementById('copy');
      btn?.addEventListener('click', async () => {
        const cmd = document.querySelector('#install code')?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(cmd.trim());
          btn.textContent = '✓';
          setTimeout(() => (btn.textContent = '⧉'), 1200);
        } catch {}
      });
      // Live star count (graceful: stays "GitHub" on failure).
      fetch('https://api.github.com/repos/RizRiyz/bohay')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('stars');
          if (el && d?.stargazers_count != null) el.textContent = `★ ${d.stargazers_count}`;
        })
        .catch(() => {});
