---
// The bohay product homepage — a custom landing page, independent of the
// Starlight docs layout (docs live under /docs/…). Dark-first, the app's own
// fluo-green (#c6ff1a) on near-black, terminal-native aesthetic.
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '@fontsource/ibm-plex-mono/700.css';
import Logo from '../assets/logo.svg';
// Authentic brand marks (24×24 SVGs) for the "works with" grid. The `-color`
// ones carry their own fills; the rest are `currentColor` (recolored via CSS,
// flagged `mono`). `hook` marks agents that also get session resume + events.
import IconClaudeCode from '../assets/icons/claudecode-color.svg';
import IconCopilot from '../assets/icons/githubcopilot.svg';
import IconCodex from '../assets/icons/codex-color.svg';
import IconOpencode from '../assets/icons/opencode.svg';
import IconCursor from '../assets/icons/cursor.svg';
import IconGemini from '../assets/icons/geminicli-color.svg';
import IconKimi from '../assets/icons/kimi-color.svg';
import IconAmp from '../assets/icons/amp-color.svg';
import IconGrok from '../assets/icons/grok.svg';
import IconQwen from '../assets/icons/qwen-color.svg';

const GITHUB = 'https://github.com/RizRiyz/bohay';

const AGENTS = [
  { name: 'Claude Code', Icon: IconClaudeCode, hook: true },
  { name: 'Copilot', Icon: IconCopilot, mono: true, hook: true },
  { name: 'Codex', Icon: IconCodex, hook: true },
  { name: 'opencode', Icon: IconOpencode, mono: true, hook: true },
  { name: 'Cursor', Icon: IconCursor, mono: true },
  { name: 'Gemini', Icon: IconGemini },
  { name: 'Kimi', Icon: IconKimi, hook: true },
  { name: 'Amp', Icon: IconAmp },
  { name: 'Grok', Icon: IconGrok, mono: true },
  { name: 'Qwen', Icon: IconQwen },
];

const cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);

// The bohay-notch demo panel — mirrors the real app's NotchModel.sample
// (bohay-notch/…/AgentModel.swift): model · project · context% · cost · state.
const NOTCH_AGENTS = [
  { id: 'claude', model: 'Sonnet 4.6', proj: 'sudos', state: 'blocked', cost: '0.67', ctx: 25, Icon: IconClaudeCode, slug: 'claudecode' },
  { id: 'codex', model: 'GPT-5', proj: 'esp-sol', state: 'working', cost: '1.20', ctx: 61, Icon: IconCodex, slug: 'codex' },
  { id: 'copilot', model: 'Claude', proj: 'notch', state: 'done', cost: '0.09', ctx: 12, Icon: IconCopilot, slug: 'copilot' },
  { id: 'opencode', model: 'Sonnet 4.6', proj: 'docs', state: 'idle', cost: '2.03', ctx: 88, Icon: IconOpencode, slug: 'opencode' },
];
const title = 'bohay: mission control for your AI coding agents';
const description =
  'Mission control for your AI coding agents. Run, watch, resume, and orchestrate Claude Code, Codex, Copilot, opencode and more from one terminal, with a live view of every agent.';
const ogImage = 'https://bohay.dev/og.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href="https://bohay.dev/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bohay.dev/" />
    <meta property="og:site_name" content="bohay" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <nav>
      <div class="nav-inner">
      <a class="brand" href="/">
        <Logo width={28} height={28} class="mark" aria-hidden="true" />
        <span>bohay</span>
      </a>
      <div class="nav-links">
        <a href="/docs/">Docs</a>
        <a href="/modules/">Modules</a>
        <a href="/compare/">Compare</a>
        <a href="/changelog/">Changelog</a>
        <a href={GITHUB} class="gh">
          <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"
            ><path
              fill="currentColor"
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path></svg
          >
          <span id="stars">GitHub</span>
        </a>
      </div>
      </div>
    </nav>

    <header class="hero">
      <div class="glow" aria-hidden="true"></div>
      <h1>Next-Gen mission control<br /><span class="accent">for your AI agents</span></h1>
      <p class="sub">
        One place to run, watch, resume, and orchestrate every coding agent.
      </p>

      <div class="install" id="install">
        <code>curl -fsSL https://bohay.dev/install.sh | sh</code>
        <button id="copy" aria-label="Copy install command" title="Copy">⧉</button>
      </div>
      <p class="alt-install">
        or <code>brew install RizRiyz/bohay/bohay</code> · <code>cargo install bohay</code> ·
        <a href="/docs/getting-started/installation/">Windows &amp; more</a>
      </p>

      <div class="cta">
        <a class="btn primary" href="/docs/">Get started →</a>
        <a class="btn" href={GITHUB}>Star on GitHub</a>
      </div>

      <!-- Live, clickable simulation of the real UI, not a screenshot. -->
      <div class="demo" id="demo">
        <div class="demo-chrome">
          <span class="tl r"></span><span class="tl y"></span><span class="tl g"></span>
          <span class="demo-title">bohay · sudos</span>
          <span class="demo-hint">● live demo · click around</span>
        </div>
        <div class="demo-body">
          <aside class="demo-side">
            <div class="side-brand">
              <Logo width={16} height={16} class="mark" aria-hidden="true" />
              <span class="side-name">bohay</span>
              <span class="side-ver">v0.7</span>
              <button class="menu-pill" id="menu-pill" title="Settings · theme · keys · language">Menu</button>
            </div>
            <div class="side-label">Workspaces</div>
            <button class="ws on" data-ws="sudos">
              <span class="ws-arrow">▾</span> sudos <span class="branch">⎇ main</span><span class="ab">↑2</span>
            </button>
            <button class="ws" data-ws="webapp">
              <span class="ws-arrow">▸</span> webapp <span class="branch">⎇ feat/ui</span>
            </button>
            <div class="side-label agents-label">
              <span>Agents</span>
              <span class="afilter">
                <button class="fchip" data-f="all">All</button><button class="fchip on" data-f="active">Active</button>
              </span>
            </div>
            <button class="agent focused" data-agent="claude">
              <span class="dot working" id="dot-claude"></span>claude<span class="proj">sudos</span>
            </button>
            <button class="agent" data-agent="copilot">
              <span class="dot blocked" id="dot-copilot"></span>copilot<span class="proj">webapp</span>
            </button>
            <button class="agent" data-agent="codex">
              <span class="dot done" id="dot-codex"></span>codex<span class="proj">sudos</span>
            </button>
            <button class="session-row" id="session-row" hidden>
              <span class="c-dim">↺</span> claude <span class="proj">2h ago · api</span>
            </button>
          </aside>
          <div class="demo-main">
            <div class="demo-tabs">
              <button class="tab on" data-tab="main">1 main</button>
              <button class="tab" data-tab="git">2 ⎇ git</button>
              <button class="tab" data-tab="orch">3 ◇ orch</button>
              <span class="tab plus">+</span>
            </div>

            <div class="demo-view" id="view-main">
              <div class="demo-panes" id="ws-sudos">
                <div class="pane focused" id="pane-left" data-agent="claude">
                  <div class="pane-title" id="left-title"><span class="pt-dot working"></span>claude · ~/sudos</div>
                  <div class="pane-body" id="left-body"></div>
                </div>
                <div class="pane" id="pane-codex" data-agent="codex">
                  <div class="pane-title" id="codex-title"><span class="pt-dot done"></span>codex · ~/sudos</div>
                  <div class="pane-body" id="codex-body"></div>
                </div>
              </div>
              <div class="demo-panes" id="ws-webapp" hidden>
                <div class="pane" id="pane-copilot" data-agent="copilot">
                  <div class="pane-title" id="copilot-title"><span class="pt-dot blocked"></span>copilot · ~/webapp</div>
                  <div class="pane-body" id="copilot-body"></div>
                </div>
              </div>
            </div>

            <div class="demo-view gview" id="view-git" hidden>
              <div class="gtabs">
                <button class="gtab on" data-g="commits">Commits</button>
                <button class="gtab" data-g="flow">Flow</button>
                <button class="gtab" data-g="branches">Branches</button>
                <button class="gtab" data-g="prs">PRs</button>
                <button class="gtab" data-g="issues">Issues</button>
                <button class="gtab" data-g="status">Status</button>
              </div>
              <div class="gbody" id="gbody"></div>
            </div>

            <div class="demo-view gview" id="view-orch" hidden>
              <div class="oheader"><span class="c-acc">◇ orch</span>&nbsp; 4 tasks <span class="sep">·</span> queued 1 <span class="sep">·</span> running 2 <span class="sep">·</span> done 1</div>
              <div class="gbody" id="obody"></div>
              <div class="oleases"><span class="c-acc">LEASES</span>&nbsp; L1 <span class="c-dim">pane 4</span> t2 <span class="c-acc">src/api/**</span> &nbsp; L2 <span class="c-dim">pane 5</span> t3 <span class="c-acc">docs/**</span></div>
            </div>

            <div class="demo-status">
              <span class="pill">⌃Space</span><span class="dim"> prefix</span>
              <span class="sep">·</span> <span id="status-note">copilot is blocked · click its pane to approve</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="features">
      <h2>Everything your agents need, in one place</h2>
      <p class="feat-sub">One terminal that watches every agent, keeps your work safe, and ships your code without switching windows.</p>
      <div class="grid" id="feat-grid">
        <a class="card s4" href="/docs/guides/agents/">
          <div class="card-ic">◉</div>
          <h3>See every agent at a glance</h3>
          <p>One sidebar shows what each agent is doing right now: waiting on you, working, finished, or resting. Status you can trust, too: an agent only counts as working when it really is, so a starting CLI or your own typing never reads as busy. An optional retro chime tells you the moment one finishes or needs you.</p>
          <div class="fx-strip" aria-hidden="true">
            <span class="fx-chip blocked"><i></i>claude · waiting</span>
            <span class="fx-chip working"><i></i>codex · working</span>
            <span class="fx-chip done"><i></i>copilot · done</span>
            <span class="fx-chip idle"><i></i>opencode · resting</span>
          </div>
          <span class="card-go">See the agent view</span>
        </a>
        <a class="card s2" href="/docs/guides/agents/">
          <div class="card-ic">⌘</div>
          <h3>See what an agent is really running</h3>
          <p>Agents shorten long commands on screen. Click a pane's title for the real one, in full, straight from the system.</p>
          <span class="card-go">Inspect a pane</span>
        </a>
        <a class="card s2" href="/docs/getting-started/first-session/">
          <div class="card-ic">∞</div>
          <h3>Pick up where you left off</h3>
          <p>Close the terminal and nothing stops. Open it again and every pane, tab, and layout is right where you left it.</p>
          <span class="card-go">How sessions work</span>
        </a>
        <a class="card s2" href="/docs/guides/agents/#session-resume--the-flagship">
          <div class="card-ic">↺</div>
          <h3>Your agents remember too</h3>
          <p>After a restart, each agent reloads its own chat history by itself. You never paste a session flag or lose the thread.</p>
          <span class="card-go">About resume</span>
        </a>
        <a class="card s4" href="/docs/guides/orchestration/">
          <div class="card-ic">◇</div>
          <h3>Run a whole team at once</h3>
          <p>Put many agents on one project together without stepping on each other. Every agent works in its own copy, claims the files it touches, and only merges once your tests pass.</p>
          <div class="fx-tasks" aria-hidden="true">
            <span class="fx-task"><i class="fx-td done"></i>OAuth module<b class="fx-tag done">done</b></span>
            <span class="fx-task"><i class="fx-td run"></i>API layer<b class="fx-tag run">running</b></span>
            <span class="fx-task"><i class="fx-td q"></i>Integration tests<b class="fx-tag q">queued</b></span>
          </div>
          <span class="card-go">Meet the task board</span>
        </a>
        <a class="card s3" href="/docs/guides/git/">
          <div class="card-ic">⎇</div>
          <h3>Git without leaving</h3>
          <p>Browse commits, branches, pull requests, and issues in a built in tab. Open a pull request or merge it right there, without touching another app.</p>
          <span class="card-go">Explore the git tab</span>
        </a>
        <a class="card s3" href="/docs/guides/remote/">
          <div class="card-ic">⇄</div>
          <h3>Work on any machine</h3>
          <p>Drive a session running on another computer straight from your laptop over plain SSH. No port forwarding to set up, and it still feels instant as you type.</p>
          <span class="card-go">Set up remote</span>
        </a>
      </div>
    </section>

    <section class="orch">
      <div class="orch-text">
        <h2>Several agents. One repo.<br /><span class="accent">Zero conflicts.</span></h2>
        <p>
          Add tasks with dependencies to the <code>◇ orch</code> board. Each
          started task gets an <strong>isolated git worktree</strong> and its own
          pane; <strong>path leases</strong> stop overlapping edits from even
          being assigned; a <strong>quality gate</strong> (your test command)
          must pass before a task counts as done; and finished branches merge
          through a dedicated worktree,<strong>your checkout is never
          touched</strong>.
        </p>
        <a class="btn primary" href="/docs/guides/orchestration/">Read the orchestration guide →</a>
      </div>
      <div class="orch-card" aria-hidden="true">
        <div class="oc-head">
          <span class="oc-title">◇ orch</span>
          <span class="oc-counts">
            <span class="ocount"><i class="d done"></i>1 done</span>
            <span class="ocount"><i class="d run"></i>2 running</span>
            <span class="ocount"><i class="d queue"></i>1 queued</span>
          </span>
        </div>
        <div class="oc-rows">
          <div class="oc-row"><i class="d done"></i><b>t1</b><span class="pill done">done</span><span class="oc-name">OAuth token module</span><span class="oc-meta">gate ✓</span></div>
          <div class="oc-row"><i class="d run"></i><b>t2</b><span class="pill run">running</span><span class="oc-name">API layer</span><span class="oc-meta">bohay/t2</span></div>
          <div class="oc-row"><i class="d run"></i><b>t3</b><span class="pill run">running</span><span class="oc-name">Docs + examples</span><span class="oc-meta">bohay/t3</span></div>
          <div class="oc-row"><i class="d queue"></i><b>t4</b><span class="pill queue">queued</span><span class="oc-name">Integration tests</span><span class="oc-meta">⟶ t2 t3</span></div>
        </div>
        <div class="oc-leases">
          <span class="oc-lk">LEASES</span>
          <span class="lease">L1 <em>src/api/**</em></span>
          <span class="lease">L2 <em>docs/**</em></span>
        </div>
      </div>
    </section>

    <!-- The bohay-notch showcase: a full macOS screen with monitor, approve,
         and jump. An interactive replica of the real app (bohay-notch/). -->
    <section class="macshow">
      <h2 class="ms-title">Your agent team, in the notch</h2>
      <p class="ms-sub">
        <strong>bohay-notch</strong> mirrors every agent into a native macOS panel that drops
        from the MacBook notch. <b>Monitor</b> them, <b>approve</b> a request or answer a
        question, and <b>jump</b> straight to any pane, all without breaking flow.
      </p>

      <div class="mac">
        <div class="screen">
          <div class="menubar">
            <span class="mb-l"><span class="mb-logo"></span> <b>bohay</b> <span class="mb-mi">File</span> <span class="mb-mi">View</span> <span class="mb-mi">Agents</span></span>
            <span class="mb-r">100%&nbsp;&nbsp;Tue&nbsp;9:41</span>
          </div>
          <div class="desk">
            <div class="termwin" id="termwin">
              <div class="tw-bar"><span class="tl r"></span><span class="tl y"></span><span class="tl g"></span><span class="tw-title" id="tw-title">claude · ~/sudos</span></div>
              <div class="tw-body">
                <div class="tw-side">
                  <div class="tw-slabel">Agents</div>
                  {NOTCH_AGENTS.map((a) => (
                    <button class="tw-agent" data-jump={a.id}><i class={`tsd ${a.state}`} data-sd={a.id}></i>{a.id}</button>
                  ))}
                </div>
                <div class="tw-pane" id="tw-pane"></div>
              </div>
            </div>
            <div class="jtoast" id="jtoast"></div>
          </div>

          <div class="island" id="island">
            <span class="ncamera"></span>
            <div class="ncollapsed">
              <span class="ncol-l"><i class="sumdot working" id="sumdot"></i><b id="sumcount">4</b></span>
              <span class="ncol-r"><span class="ndisc ic-claudecode"><IconClaudeCode /></span></span>
            </div>
            <div class="npanel" id="npanel">
              <div class="nview" id="nview-list">
                <div class="nhead"><span class="nhead-t">AGENTS</span><i class="ndot green"></i><span class="nspacer"></span><b>4</b></div>
                <div class="nrows">
                  {NOTCH_AGENTS.map((a) => (
                    <button class="nrow" data-jump={a.id}>
                      <span class={`ndisc ic-${a.slug}`}><a.Icon /></span>
                      <span class="nmodel">{a.model}</span>
                      <span class="nproj">{a.proj}</span>
                      <span class="nspacer"></span>
                      <span class="nctx"><span class="nctx-bar"><i class={a.ctx >= 85 ? 'red' : a.ctx >= 60 ? 'amber' : 'grn'} style={`width:${a.ctx}%`}></i></span><span class="nctx-n">{a.ctx}%</span></span>
                      <span class="ncost">${a.cost}</span>
                      <span class={`npill ${a.state}`} data-pill={a.id}>{cap(a.state)}</span>
                    </button>
                  ))}
                </div>
                <div class="nfoot">
                  <span class="fstat"><i class="ndot green"></i><b id="f-run">2</b> running</span>
                  <span class="fstat"><i class="ndot done"></i><b id="f-done">1</b> done</span>
                  <span class="fstat"><i class="ndot idle"></i><b id="f-idle">1</b> idle</span>
                  <span class="nspacer"></span><b class="ftotal">$3.99</b><span class="ftot-l">total</span>
                </div>
              </div>
              <div class="nview" id="nview-approve" hidden>
                <div class="ncard-head"><span class="ncard-hand">✋</span><b>claude</b><span class="nproj">sudos</span><span class="nspacer"></span><span class="ncard-open">⧉</span></div>
                <div class="ncard-ctx">Claude wants to run a command</div>
                <div class="ncard-q">Run <b>cargo&nbsp;test</b> in <b>sudos</b>?</div>
                <div class="ncard-opts">
                  <button class="nopt allow" data-answer="yes"><span class="nnum">1</span><span class="nopt-l">Yes</span><span class="nkey">⌘Y</span></button>
                  <button class="nopt" data-answer="always"><span class="nnum">2</span><span class="nopt-l">Yes, and don't ask again</span></button>
                  <button class="nopt deny" data-answer="no"><span class="nnum">3</span><span class="nopt-l">No, keep working</span><span class="nkey">⌘N</span></button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="caps" id="caps">
        <button class="cap on" data-cap="monitor"><b>Monitor</b><span>every agent, one glance</span></button>
        <button class="cap" data-cap="approve"><b>Approve</b><span>answer &amp; grant permission</span></button>
        <button class="cap" data-cap="jump"><b>Jump</b><span>focus its pane</span></button>
      </div>

      <div class="ms-foot">
        <code class="cask">brew install --cask --no-quarantine RizRiyz/bohay/bohay-notch</code>
        <span class="ms-req">macOS 15+ · Apple silicon · <a href="https://github.com/RizRiyz/bohay/releases">or download the .dmg</a></span>
      </div>
    </section>

    <section class="agents-strip">
      <h2>Works with the agents you already use</h2>
      <div class="agent-grid">
        {AGENTS.map(({ name, Icon, hook }) => (
          <div class={`atile${hook ? ' hook' : ''}`}>
            <span class={`aicon ic-${name.toLowerCase().replace(/[^a-z0-9]/g, '')}`} aria-label={name}>
              <Icon />
            </span>
            <span class="aname">{name}</span>
          </div>
        ))}
      </div>
      <p class="note">
        …plus <strong>Aider</strong>, <strong>Droid</strong>, and any agent bohay
        recognizes on screen. Live status for all, zero setup. The
        <span class="hookdot">●</span> agents also resume sessions &amp; report precise events.
        <a href="/docs/reference/agents/">Full matrix →</a>
      </p>
    </section>


    <section class="cta-repo">
      <div class="cta-card">
        <span class="cta-badge">Open source · MIT licensed</span>
        <h2>If bohay saves you time, give it a star</h2>
        <p>
          bohay is free and fully open source. A star helps more people running AI
          agents find it, and you are welcome to read the code, open an issue, or
          send a pull request any time.
        </p>
        <div class="cta-actions">
          <a class="btn primary" href={GITHUB}>
            <svg class="cta-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.2l2.95 5.98 6.6.96-4.77 4.65 1.13 6.57L12 17.98l-5.9 3.1 1.13-6.56L2.45 9.14l6.6-.96z"/></svg>
            Star on GitHub
          </a>
          <a class="btn" href={GITHUB}>
            <svg class="cta-ic" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.21 2.2.82a7.6 7.6 0 014 0c1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Browse the code
          </a>
        </div>
        <div class="cta-mini">
          <code class="cta-repo-path">github.com/RizRiyz/bohay</code>
          <a href={`${GITHUB}/issues`}>Open an issue</a>
          <span class="sep">·</span>
          <a href="/docs/">Read the docs</a>
          <span class="sep">·</span>
          <a href="https://crates.io/crates/bohay">crates.io</a>
        </div>
      </div>
    </section>

    <footer>
      <div class="foot-inner">
        <div class="foot-brand">
          <Logo width={22} height={22} class="mark" aria-hidden="true" />
          <span>bohay</span>
          <span class="dim">by Riz</span>
        </div>
        <div class="foot-links">
          <a href={GITHUB}>github</a>
          <a href="https://crates.io/crates/bohay">crates.io</a>
        </div>
      </div>
    </footer>

    <script>
      // ── The hero demo: a tiny state machine over three simulated agents. ──
      type AgentId = 'claude' | 'copilot' | 'codex';
      type Status = 'working' | 'blocked' | 'done' | 'idle';

      const CLAUDE_LINES = [
        '<span class="c-dim">⏺</span> Reading <span class="c-acc">src/app/dispatch.rs</span>…',
        '<span class="c-dim">⏺</span> The debounce needs a dwell before Idle commits.',
        '<span class="c-grn">✓</span> Edit <span class="c-acc">src/app/mod.rs</span> <span class="c-dim">(+14 -3)</span>',
        '<span class="c-dim">⏺</span> Running <span class="c-acc">cargo test</span>…',
        '<span class="c-grn">✓</span> 143 tests passed <span class="c-dim">in 6.1s</span>',
        '<span class="c-dim">⏺</span> Now updating the docs to match…',
        '<span class="c-grn">✓</span> Edit <span class="c-acc">docs/07-agent-detection.md</span>',
        '<span class="c-dim">⏺</span> Checking the render hot path stayed fast…',
        '<span class="c-grn">✓</span> 1.29&hairsp;ms/frame · no regression',
      ];
      const CODEX_DONE = [
        '<span class="c-grn">✓</span> Refactored <span class="c-acc">parser.ts</span> · 12 files changed',
        '<span class="c-grn">✓</span> npm test: <span class="c-grn">48 passed</span>',
        '<span class="c-dim">Session saved · resumable any time.</span>',
        '<span class="c-mint">agent finished · press ⏎ in the sidebar to review</span>',
      ];
      const PROMPT = `
        <div class="perm">
          <div class="perm-q">Run <span class="c-acc">npm run deploy</span>?</div>
          <button class="perm-btn yes" data-approve="yes">❯ 1. Yes</button>
          <button class="perm-btn" data-approve="no">&nbsp;&nbsp;2. No</button>
        </div>`;
      const COPILOT_LINES = [
        '<span class="c-grn">✓</span> Approved · deploying…',
        '<span class="c-dim">⏺</span> build: <span class="c-grn">ok</span> · upload: <span class="c-grn">ok</span>',
        '<span class="c-grn">✓</span> Deployed to staging <span class="c-dim">in 14s</span>',
      ];

      const $ = (id: string) => document.getElementById(id);
      const statuses: Record<AgentId, Status> = { claude: 'working', copilot: 'blocked', codex: 'done' };
      // Like the real data model: each agent's pane lives in a workspace.
      const WS_OF: Record<AgentId, 'sudos' | 'webapp'> = { claude: 'sudos', copilot: 'webapp', codex: 'sudos' };
      const PANE_OF: Record<AgentId, string> = { claude: 'pane-left', copilot: 'pane-copilot', codex: 'pane-codex' };
      let activeWs: 'sudos' | 'webapp' = 'sudos';
      let focusedAgent: AgentId = 'claude';
      let copilotStep = -1; // -1 = showing the prompt

      function mainHint(): string {
        if (activeWs === 'webapp')
          return statuses.copilot === 'blocked'
            ? 'copilot is blocked · click ❯ Yes to approve'
            : statuses.copilot === 'working'
              ? 'copilot deploying · watch it flip to done'
              : 'click a workspace or agent in the sidebar';
        return statuses.copilot === 'blocked'
          ? 'copilot is blocked in webapp · click it in the sidebar'
          : '2 panes · click workspaces and agents in the sidebar';
      }

      function setDot(agent: AgentId, status: Status) {
        statuses[agent] = status;
        const dot = $(`dot-${agent}`);
        if (dot) dot.className = `dot ${status}`;
        $(`${agent === 'claude' ? 'left' : agent}-title`)
          ?.querySelector('.pt-dot')
          ?.setAttribute('class', `pt-dot ${status}`);
        const note = $('status-note');
        if (note && activeTab === 'main') note.textContent = mainHint();
      }

      function push(bodyId: string, html: string, max = 9) {
        const body = $(bodyId);
        if (!body) return;
        const line = document.createElement('div');
        line.className = 'tline';
        line.innerHTML = html;
        body.appendChild(line);
        while (body.children.length > max) body.removeChild(body.children[0]);
      }

      function switchWs(ws: 'sudos' | 'webapp') {
        activeWs = ws;
        ($('ws-sudos') as HTMLElement).hidden = ws !== 'sudos';
        ($('ws-webapp') as HTMLElement).hidden = ws !== 'webapp';
        document.querySelectorAll('.ws').forEach((w) => {
          const on = w.getAttribute('data-ws') === ws;
          w.classList.toggle('on', on);
          const arrow = w.querySelector('.ws-arrow');
          if (arrow) arrow.textContent = on ? '▾' : '▸';
        });
        if (activeTab === 'main') {
          const note = $('status-note');
          if (note) note.textContent = mainHint();
        }
      }

      function focusAgent(agent: AgentId) {
        focusedAgent = agent;
        switchWs(WS_OF[agent]);
        document.querySelectorAll('.pane').forEach((p) => p.classList.remove('focused'));
        $(PANE_OF[agent])?.classList.add('focused');
        document.querySelectorAll('.agent').forEach((a) =>
          a.classList.toggle('focused', a.getAttribute('data-agent') === agent)
        );
      }

      function renderCopilot() {
        const body = $('copilot-body');
        if (!body) return;
        body.innerHTML = '';
        if (statuses.copilot === 'blocked') body.innerHTML = PROMPT;
        else COPILOT_LINES.slice(0, Math.max(copilotStep, 0) + 1).forEach((l) => push('copilot-body', l));
      }

      // Claude streams forever (with natural pauses — like a real turn).
      let li = 0;
      function claudeTick() {
        push('left-body', CLAUDE_LINES[li % CLAUDE_LINES.length]);
        li++;
        setDot('claude', 'working');
        setTimeout(claudeTick, 700 + Math.random() * 1400);
      }

      // Copilot: approve → stream → done → (loop back to blocked).
      function approve(yes: boolean) {
        const body = $('copilot-body');
        if (!body || statuses.copilot !== 'blocked') return;
        if (!yes) {
          body.innerHTML = '<div class="tline c-dim">Denied. Agent is idle.</div>';
          setDot('copilot', 'idle');
          setTimeout(resetCopilot, 3500);
          return;
        }
        body.innerHTML = '';
        setDot('copilot', 'working');
        copilotStep = 0;
        const step = () => {
          push('copilot-body', COPILOT_LINES[copilotStep]);
          copilotStep++;
          if (copilotStep < COPILOT_LINES.length) setTimeout(step, 1100);
          else {
            setDot('copilot', 'done');
            setTimeout(resetCopilot, 6000);
          }
        };
        step();
      }
      function resetCopilot() {
        copilotStep = -1;
        setDot('copilot', 'blocked');
        renderCopilot();
      }

      // Wiring: workspaces, agents, panes, the agents filter, the Menu pill.
      document.querySelectorAll('.ws').forEach((w) =>
        w.addEventListener('click', () => {
          switchTab('main');
          switchWs(w.getAttribute('data-ws') as 'sudos' | 'webapp');
        })
      );
      document.querySelectorAll('.agent').forEach((a) =>
        a.addEventListener('click', () => {
          switchTab('main');
          focusAgent(a.getAttribute('data-agent') as AgentId);
        })
      );
      $('pane-left')?.addEventListener('click', () => focusAgent('claude'));
      $('pane-codex')?.addEventListener('click', () => focusAgent('codex'));
      $('pane-copilot')?.addEventListener('click', (e) => {
        focusAgent('copilot');
        const t = (e.target as HTMLElement).closest('[data-approve]');
        if (t) approve(t.getAttribute('data-approve') === 'yes');
      });
      document.querySelectorAll('.fchip').forEach((c) =>
        c.addEventListener('click', () => {
          const all = c.getAttribute('data-f') === 'all';
          document.querySelectorAll('.fchip').forEach((x) =>
            x.classList.toggle('on', x === c)
          );
          ($('session-row') as HTMLElement).hidden = !all;
        })
      );
      $('session-row')?.addEventListener('click', () => {
        const note = $('status-note');
        if (note) note.textContent = 'resume reopens that conversation in a pane · try it in the real bohay';
      });
      $('menu-pill')?.addEventListener('click', () => {
        const note = $('status-note');
        if (note) note.textContent = 'Settings lives here · theme · layout · keys · language (8 languages)';
      });

      // ── Tabs: main / git / orch — like the real thing. ──
      const GIT_VIEWS: Record<string, string> = {
        commits: [
          '<div class="grow"><span class="c-acc">●</span> <span class="c-dim">2948ec7</span> release: v0.7.0 <span class="grow-meta">RizRiyz · 2h</span></div>',
          '<div class="grow"><span class="c-acc">●</span> <span class="c-dim">76acba8</span> fix: close audit findings · security, resilience <span class="grow-meta">RizRiyz · 3h</span></div>',
          '<div class="grow"><span class="c-acc">●</span> <span class="c-dim">44d5b3e</span> release: v0.6.1 <span class="grow-meta">RizRiyz · 1d</span></div>',
          '<div class="grow"><span class="c-acc">●</span> <span class="c-dim">0108c20</span> feat: scrollable panes · wheel + scroll mode <span class="grow-meta">RizRiyz · 1d</span></div>',
          '<div class="grow"><span class="c-acc">●</span> <span class="c-dim">eaf0a7a</span> docs: update readme and add new screenshot <span class="grow-meta">RizRiyz · 2d</span></div>',
        ].join(''),
        flow: [
          '<div class="tline"><span class="c-acc">main</span> ──●──●──●──●──▶</div>',
          '<div class="tline c-dim">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\\</div>',
          '<div class="tline">&nbsp;&nbsp;<span class="c-mint">bohay/t2</span> ●──● &nbsp;<span class="c-dim">↑2 ·</span> PR <span class="c-acc">#14</span></div>',
          '<div class="tline c-dim">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\\</div>',
          '<div class="tline">&nbsp;&nbsp;<span class="c-mint">bohay/t3</span> ● &nbsp;<span class="c-dim">↑1</span></div>',
        ].join(''),
        branches: [
          '<div class="grow"><span class="c-acc">● main</span> <span class="c-dim">↑0 ↓0</span> &nbsp;release: v0.7.0 <span class="grow-meta">2h</span></div>',
          '<div class="grow">&nbsp;&nbsp;audit-release <span class="c-dim">↑2 ↓0</span> &nbsp;fix: socket perms <span class="grow-meta">5h</span></div>',
          '<div class="grow">&nbsp;&nbsp;bohay/t2 <span class="c-dim">↑1 ↓0</span> &nbsp;wip: api layer <span class="grow-meta">1h</span></div>',
          '<div class="grow">&nbsp;&nbsp;bohay/t3 <span class="c-dim">↑1 ↓0</span> &nbsp;docs + examples <span class="grow-meta">30m</span></div>',
        ].join(''),
        prs: [
          '<div class="grow"><span class="c-dim">#14</span> feat: api layer <span class="c-amber">● checks running</span> <span class="grow-meta">open</span></div>',
          '<div class="grow"><span class="c-dim">#13</span> fix: close audit findings <span class="c-grn">✓ checks</span> <span class="grow-meta">merged</span></div>',
          '<div class="grow"><span class="c-dim">#12</span> feat: bohay-notch config <span class="c-grn">✓ checks</span> <span class="grow-meta">merged</span></div>',
        ].join(''),
        issues: [
          '<div class="grow"><span class="c-dim">#9</span> scroll mode on Windows Terminal <span class="grow-meta">enhancement</span></div>',
          '<div class="grow"><span class="c-dim">#7</span> gemini session resume <span class="grow-meta">help wanted</span></div>',
        ].join(''),
        status: [
          '<div class="tline"><span class="c-dim">origin</span> &nbsp;github.com/RizRiyz/bohay <span class="c-dim">· 47 commits · 4 weeks</span></div>',
          '<div class="tline">RizRiyz &nbsp;<span class="c-acc">████████████░</span> 46</div>',
          '<div class="tline"><span class="c-dim">bot</span> &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;░ 1</div>',
          '<div class="tline c-grn">working tree: clean</div>',
        ].join(''),
      };
      const ORCH_ROWS = [
        '<span class="c-mint">●</span> t1 <span class="c-mint">done</span>&nbsp;&nbsp;&nbsp; OAuth token module <span class="grow-meta">gate ✓ cargo test auth</span>',
        '<span class="c-amber">◐</span> t2 <span class="c-amber">running</span> API layer <span class="grow-meta">⟶t1 · pane 4 · bohay/t2</span>',
        '<span class="c-amber">◐</span> t3 <span class="c-amber">running</span> Docs + examples <span class="grow-meta">pane 5 · bohay/t3</span>',
        '<span class="c-dim">○</span> t4 <span class="c-dim">queued</span>&nbsp; Integration tests <span class="grow-meta">⟶t2 t3</span>',
      ];
      const STATUS_HINTS: Record<string, () => string> = {
        main: () => mainHint(),
        git: () => 'the git tab: click the sections · commits · flow · branches · PRs',
        orch: () => 'the orchestration board · click a task to select it',
      };
      let activeTab = 'main';

      function setStatusHint() {
        const note = $('status-note');
        if (note) note.textContent = STATUS_HINTS[activeTab]();
      }
      function showGit(section: string) {
        const body = $('gbody');
        if (body) body.innerHTML = GIT_VIEWS[section];
        document.querySelectorAll('.gtab').forEach((t) =>
          t.classList.toggle('on', t.getAttribute('data-g') === section)
        );
      }
      function renderOrch(selected: number) {
        const body = $('obody');
        if (!body) return;
        body.innerHTML = ORCH_ROWS.map(
          (r, i) => `<button class="grow orow ${i === selected ? 'sel' : ''}" data-row="${i}">${r}</button>`
        ).join('');
        body.querySelectorAll('.orow').forEach((r) =>
          r.addEventListener('click', () => renderOrch(Number(r.getAttribute('data-row'))))
        );
      }
      function switchTab(tab: string) {
        activeTab = tab;
        ['main', 'git', 'orch'].forEach((t) => {
          const v = $(`view-${t}`);
          if (v) (v as HTMLElement).hidden = t !== tab;
        });
        document.querySelectorAll('.demo-tabs .tab[data-tab]').forEach((t) =>
          t.classList.toggle('on', t.getAttribute('data-tab') === tab)
        );
        setStatusHint();
      }
      document.querySelectorAll('.demo-tabs .tab[data-tab]').forEach((t) =>
        t.addEventListener('click', () => switchTab(t.getAttribute('data-tab') ?? 'main'))
      );
      document.querySelectorAll('.gtab').forEach((t) =>
        t.addEventListener('click', () => showGit(t.getAttribute('data-g') ?? 'commits'))
      );

      if ($('demo')) {
        CODEX_DONE.forEach((l) => push('codex-body', l));
        renderCopilot();
        focusAgent('claude');
        claudeTick();
        showGit('commits');
        renderOrch(1);
        setStatusHint();
        // Deep-linkable demo state: /?demo=git or /?demo=orch opens that tab.
        const deep = new URLSearchParams(location.search).get('demo');
        if (deep === 'git' || deep === 'orch') switchTab(deep);
      }

      // ── The bohay-notch Mac-screen showcase: Monitor · Approve · Ask · Jump. ──
      const island = $('island');
      if (island) {
        type Cap = 'monitor' | 'approve' | 'jump';

        // Terminal pane content per focused agent (+ special claude states).
        const PANE: Record<string, string[]> = {
          claude: [
            '<span class="c-dim">⏺</span> Reading <span class="c-acc">src/app/dispatch.rs</span>…',
            '<span class="c-grn">✓</span> Edit <span class="c-acc">src/app/mod.rs</span> <span class="c-dim">(+14 -3)</span>',
            '<span class="c-dim">⏺</span> Running <span class="c-acc">cargo test</span>… <span class="c-grn">143 passed</span>',
          ],
          'claude-approve': [
            '<span class="c-dim">⏺</span> Ready to run the test suite…',
            '<span class="c-amber">⏸ waiting · answer in the notch ↑</span>',
          ],
          'claude-done': [
            '<span class="c-dim">⏺</span> Running <span class="c-acc">cargo test</span>…',
            '<span class="c-grn">✓</span> 143 passed <span class="c-dim">· 2.1s</span>',
          ],
          codex: [
            '<span class="c-dim">⏺</span> Editing <span class="c-acc">firmware.rs</span>…',
            '<span class="c-dim">⏺</span> Flashing ESP32 <span class="c-dim">· 61% ctx</span>',
          ],
          copilot: [
            '<span class="c-grn">✓</span> Build finished <span class="c-dim">in 14s</span>',
            '<span class="c-mint">done · ready to review</span>',
          ],
          opencode: ['<span class="c-dim">idle · waiting for input</span>'],
        };
        const CWD: Record<string, string> = { claude: '~/sudos', codex: '~/esp-sol', copilot: '~/notch', opencode: '~/docs' };

        // The island height hugs whichever view is visible (no dead space).
        const sizeIsland = () => {
          if (island.classList.contains('open'))
            island.style.height = ($('npanel') as HTMLElement).scrollHeight + 'px';
        };
        const showView = (v: 'list' | 'approve') => {
          ($('nview-list') as HTMLElement).hidden = v !== 'list';
          ($('nview-approve') as HTMLElement).hidden = v !== 'approve';
          sizeIsland();
        };
        const setSummary = (blocked: boolean) => {
          const d = $('sumdot');
          if (d) d.className = 'sumdot ' + (blocked ? 'blocked' : 'working');
        };
        const setClaudePill = (state: string) => {
          const pill = document.querySelector('[data-pill="claude"]');
          if (pill) { pill.className = 'npill ' + state; pill.textContent = state.charAt(0).toUpperCase() + state.slice(1); }
          document.querySelector('[data-sd="claude"]')?.setAttribute('class', 'tsd ' + state);
          const foot = { work: 1, done: 1, idle: 1 };
          if (state === 'blocked' || state === 'working') foot.work += 1;
          else if (state === 'done') foot.done += 1; else foot.idle += 1;
          ($('f-run') as HTMLElement).textContent = String(foot.work);
          ($('f-done') as HTMLElement).textContent = String(foot.done);
          ($('f-idle') as HTMLElement).textContent = String(foot.idle);
        };

        // Focus a terminal pane (the "Jump" payoff): swap title/body, flash a ring.
        let focused = 'claude';
        const focusTerminal = (id: string, variant = '') => {
          focused = id;
          ($('tw-title') as HTMLElement).textContent = `${id} · ${CWD[id] ?? '~'}`;
          const lines = PANE[variant || id] ?? PANE[id] ?? [];
          const pane = $('tw-pane') as HTMLElement;
          pane.innerHTML = lines.map((l) => `<div class="tline">${l}</div>`).join('');
          document.querySelectorAll('.tw-agent').forEach((a) =>
            a.classList.toggle('on', a.getAttribute('data-jump') === id)
          );
          const win = $('termwin');
          win?.classList.remove('flash'); void win?.offsetWidth; win?.classList.add('flash');
        };
        const toast = (msg: string) => {
          const t = $('jtoast') as HTMLElement;
          t.textContent = msg; t.classList.add('show');
          setTimeout(() => t.classList.remove('show'), 1600);
        };

        // Open / close the notch. Hovering the screen opens it; leaving closes
        // it unless a click "pinned" it open for a beat (so a tap on a cap or a
        // card answer stays visible even with the cursor off the screen).
        let hovering = false, pinned = false;
        let pinT: ReturnType<typeof setTimeout> | undefined;
        let closeT: ReturnType<typeof setTimeout> | undefined;
        const openIsland = () => { island.classList.add('open'); sizeIsland(); };
        const closeIsland = () => { island.classList.remove('open'); island.style.height = ''; };
        const pin = (ms = 2600) => {
          pinned = true; clearTimeout(pinT);
          pinT = setTimeout(() => { pinned = false; if (!hovering) closeIsland(); }, ms);
        };
        const maybeClose = () => {
          clearTimeout(closeT);
          closeT = setTimeout(() => { if (!hovering && !pinned) closeIsland(); }, 240);
        };

        // The three capabilities.
        const setCap = (cap: Cap) => {
          setActiveCap(cap);
          if (cap === 'monitor') {
            showView('list'); setSummary(false); setClaudePill('working'); focusTerminal('claude');
          } else if (cap === 'approve') {
            showView('approve'); setSummary(true); setClaudePill('blocked'); focusTerminal('claude', 'claude-approve');
          } else if (cap === 'jump') {
            showView('list'); setSummary(false); setClaudePill('working');
            focusTerminal('copilot'); toast('Jumped to copilot');
          }
        };

        // Answering the card → Claude resumes; approve runs to Done, deny keeps
        // it working. Back to the Monitor view either way.
        const answer = (deny: boolean) => {
          setActiveCap('monitor'); showView('list'); setSummary(false);
          setClaudePill('working'); focusTerminal('claude');
          if (!deny) setTimeout(() => { setClaudePill('done'); focusTerminal('claude', 'claude-done'); }, 2200);
        };
        function setActiveCap(cap: Cap) {
          document.querySelectorAll('#caps .cap').forEach((c) =>
            c.classList.toggle('on', c.getAttribute('data-cap') === cap));
        }

        // Wiring — hover the Mac screen to reveal / hide the notch.
        const mac = document.querySelector('.mac');
        mac?.addEventListener('mouseenter', () => { hovering = true; openIsland(); });
        mac?.addEventListener('mouseleave', () => { hovering = false; maybeClose(); });

        $('caps')?.addEventListener('click', (e) => {
          const b = (e.target as HTMLElement).closest('[data-cap]');
          if (b) { setCap(b.getAttribute('data-cap') as Cap); openIsland(); pin(); }
        });
        $('nview-approve')?.addEventListener('click', (e) => {
          const b = (e.target as HTMLElement).closest('[data-answer]');
          if (b) { answer(b.getAttribute('data-answer') === 'no'); openIsland(); pin(); }
        });
        // Click any agent (notch row or terminal sidebar) to jump to its pane.
        document.querySelectorAll('[data-jump]').forEach((el) =>
          el.addEventListener('click', () => {
            const id = el.getAttribute('data-jump') as string;
            focusTerminal(id); toast(`Jumped to ${id}`);
            setActiveCap('jump'); openIsland(); pin();
          })
        );

        // Seed Monitor. On a plain load, peek the island open once so first-time
        // visitors see it drop from the notch (double-rAF paints collapsed first
        // so the transition animates), then it tucks away unless hovered. A
        // `?cap=approve|jump` deep-link opens it straight away, held open.
        const params = new URLSearchParams(location.search);
        const startCap = (params.get('cap') as Cap) || 'monitor';
        setCap(['monitor', 'approve', 'jump'].includes(startCap) ? startCap : 'monitor');
        setClaudePill('working');
        if (params.has('cap')) { openIsland(); pin(6e5); }
        else requestAnimationFrame(() => requestAnimationFrame(() => { openIsland(); pin(3400); }));
      }

      // Copy the install one-liner.
      const btn = document.getElementById('copy');
      btn?.addEventListener('click', async () => {
        const cmd = document.querySelector('#install code')?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(cmd.trim());
          btn.textContent = '✓';
          setTimeout(() => (btn.textContent = '⧉'), 1200);
        } catch {}
      });
      // Live star count (graceful: stays "GitHub" on failure).
      fetch('https://api.github.com/repos/RizRiyz/bohay')
        .then((r) => (r.ok ? r.json() : null))
        .then((d) => {
          const el = document.getElementById('stars');
          if (el && d?.stargazers_count != null) el.textContent = `★ ${d.stargazers_count}`;
        })
        .catch(() => {});
    </script>

