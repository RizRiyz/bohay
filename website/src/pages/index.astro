      .d.done { background: var(--mint); }
      .d.run { background: var(--amber); }
      .d.queue { background: #4a4a54; }
      .oc-rows { padding: 0.5rem 0.6rem; }
      .oc-row {
        display: flex; align-items: center; gap: 0.6rem;
        padding: 0.42rem 0.55rem; border-radius: 0.5rem; font-size: 0.78rem;
      }
      .oc-row + .oc-row { margin-top: 1px; }
      .oc-row:hover { background: #16161d; }
      .oc-row b { color: var(--sub); font-weight: 500; min-width: 1.4rem; }
      .pill {
        font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.05em;
        padding: 0.1rem 0.5rem; border-radius: 999px; font-weight: 600; flex-shrink: 0;
      }
      .pill.done { color: var(--mint); background: rgb(111 198 163 / 0.13); }
      .pill.run { color: var(--amber); background: rgb(224 154 77 / 0.14); }
      .pill.queue { color: var(--sub); background: #1e1e26; }
      .oc-name { color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .oc-meta { margin-left: auto; color: #686873; font-size: 0.7rem; flex-shrink: 0; }
      .oc-leases {
        display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap;
        padding: 0.7rem 1.1rem; border-top: 1px solid var(--line); background: #0f0f14;
      }
      .oc-lk { color: var(--accent); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.08em; }
      .lease { color: var(--sub); font-size: 0.72rem; }
      .lease em { color: var(--accent); font-style: normal; }

      /* "Works with" · a tidy 5-by-2 grid of agent tiles. Each brand mark sits
         on a matching rounded backdrop so the mismatched logos read uniformly. */
      .agent-grid {
        display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.8rem;
        max-width: 780px; margin: 0 auto;
      }
      .atile {
        position: relative;
        display: flex; flex-direction: column; align-items: center; gap: 0.72rem;
        padding: 1.2rem 0.5rem 0.95rem; background: var(--bg2);
        border: 1px solid var(--line); border-radius: 0.9rem;
        transition: border-color 0.15s, transform 0.15s, background 0.15s;
      }
      .atile:hover { border-color: rgb(198 255 26 / 0.5); transform: translateY(-3px); background: #121109; }
      .aicon {
        display: flex; align-items: center; justify-content: center;
        width: 46px; height: 46px; border-radius: 12px;
        background: #17171e; border: 1px solid var(--line);
        font-size: 25px; color: #d2d2da;
        transition: color 0.15s, background 0.15s, border-color 0.15s;
      }
      .aicon svg { display: block; width: 1em; height: 1em; }
      /* Flatten every mark to one light color (Cursor-style), green on hover. */
      .aicon svg path { fill: currentColor; }
      .atile:hover .aicon { color: var(--accent); background: #191c0f; border-color: rgb(198 255 26 / 0.32); }
      /* Badge logos = colored square + inner glyph. Hide the square so only the
         glyph shows as a clean monochrome mark. */
      .ic-codex svg path[fill='#fff'],
      .ic-gemini svg path[fill^='url'] { display: none; }
      .aname { color: var(--sub); font-size: 0.78rem; text-align: center; }
      .atile:hover .aname { color: var(--text); }
      .atile.hook::after {
        content: ''; position: absolute; top: 0.6rem; right: 0.6rem;
        width: 6px; height: 6px; border-radius: 50%; background: var(--accent);
        box-shadow: 0 0 6px rgb(198 255 26 / 0.6);
      }
      @media (max-width: 720px) { .agent-grid { grid-template-columns: repeat(3, 1fr); max-width: 460px; } }
      @media (max-width: 440px) { .agent-grid { grid-template-columns: repeat(2, 1fr); } }
      .agents-strip .note {
        text-align: center; color: var(--sub); margin: 1.7rem auto 0;
        max-width: 44rem; font-size: 0.92rem; line-height: 1.7;
      }
      .agents-strip .note strong { color: var(--text); font-weight: 600; }
      .agents-strip .note a { color: var(--accent); }
      .hookdot { color: var(--accent); }

      .cask { display: inline-block; background: var(--bg2); border: 1px solid var(--line); border-radius: 0.5rem; padding: 0.5rem 0.8rem; font-size: 0.8rem; color: var(--accent); }

      /* ── the bohay-notch macOS showcase (matches bohay-notch/) ── */
      .macshow { text-align: center; }
      .ms-title { font-size: clamp(1.7rem, 4vw, 2.1rem); margin-bottom: 0.8rem; }
      .ms-sub { color: var(--sub); max-width: 42rem; margin: 0 auto 2.4rem; font-size: 1.02rem; line-height: 1.65; }
      .ms-sub strong { color: var(--text); }
      .ms-sub b { color: var(--accent); font-weight: 600; }

      .mac { --amber: #ff9e0a; --grn: #c6ff1a; --done: #30d159; max-width: 860px; margin: 0 auto; }
      .screen {
        position: relative; aspect-ratio: 16 / 10; border-radius: 20px; overflow: hidden;
        background: #0a0a0d;
        box-shadow: 0 40px 100px rgb(0 0 0 / 0.6), 0 0 0 6px #16161c, 0 0 0 7px #050507,
          inset 0 0 60px rgb(0 0 0 / 0.4);
      }
      .menubar {
        display: flex; justify-content: space-between; align-items: center;
        height: 26px; padding: 0 0.9rem; font-size: 0.7rem; color: rgb(255 255 255 / 0.55);
        background: rgb(0 0 0 / 0.35); border-bottom: 1px solid rgb(255 255 255 / 0.05);
      }
      .mb-l { display: flex; align-items: center; gap: 0.55rem; }
      .mb-l b { color: rgb(255 255 255 / 0.85); font-weight: 600; }
      .mb-mi { color: rgb(255 255 255 / 0.4); }
      .mb-logo { width: 9px; height: 9px; border-radius: 2px; background: var(--accent); }
      .mb-r { font-family: 'JetBrains Mono Variable', monospace; font-size: 0.66rem; }
      .desk {
        position: absolute; inset: 26px 0 0; padding: 2.6rem 1.6rem 1.6rem;
        background:
          radial-gradient(120% 95% at 10% 6%, rgb(255 126 182 / 0.85), transparent 42%),
          radial-gradient(120% 95% at 92% 10%, rgb(123 108 255 / 0.85), transparent 46%),
          radial-gradient(130% 100% at 82% 96%, rgb(34 211 170 / 0.8), transparent 48%),
          radial-gradient(120% 110% at 14% 100%, rgb(255 179 71 / 0.7), transparent 46%),
          linear-gradient(155deg, #3a2a63 0%, #1e2b52 46%, #123a3a 100%);
        display: flex; align-items: flex-end; justify-content: center;
      }
      .desk::after {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background: radial-gradient(140% 120% at 50% 0%, transparent 55%, rgb(0 0 0 / 0.35));
      }
      .termwin {
        position: relative; z-index: 1;
        width: 100%; max-width: 610px; height: 84%; display: flex; flex-direction: column;
        background: rgb(14 14 19 / 0.96); backdrop-filter: blur(8px);
        border: 1px solid rgb(255 255 255 / 0.12); border-radius: 10px;
        overflow: hidden; box-shadow: 0 30px 70px rgb(0 0 0 / 0.55); transition: box-shadow 0.2s;
      }
      .termwin.flash { box-shadow: 0 0 0 1.5px var(--accent), 0 24px 60px rgb(0 0 0 / 0.5); }
      .tw-bar { display: flex; align-items: center; gap: 0.4rem; padding: 0.45rem 0.7rem; border-bottom: 1px solid rgb(255 255 255 / 0.06); }
      .tw-title { margin-left: 0.5rem; font: 0.68rem 'JetBrains Mono Variable', monospace; color: rgb(255 255 255 / 0.6); }
      .tw-body { flex: 1; display: flex; min-height: 0; }
      .tw-side { width: 106px; flex-shrink: 0; border-right: 1px solid rgb(255 255 255 / 0.06); padding: 0.5rem 0.3rem; }
      .tw-slabel { font-size: 0.56rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgb(255 255 255 / 0.35); padding: 0.15rem 0.4rem 0.4rem; }
      .tw-agent {
        display: flex; align-items: center; gap: 0.4rem; width: 100%;
        background: none; border: 0; cursor: pointer; text-align: left; color: rgb(255 255 255 / 0.7);
        padding: 0.3rem 0.4rem; border-radius: 0.35rem; font: 0.72rem 'JetBrains Mono Variable', monospace;
      }
      .tw-agent:hover { background: rgb(255 255 255 / 0.05); color: #fff; }
      .tw-agent.on { background: #1d240b; color: var(--accent); }
      .tsd { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
      .tsd.working { background: var(--grn); } .tsd.blocked { background: var(--amber); animation: pulse 1s infinite; }
      .tsd.done { background: var(--done); } .tsd.idle { background: #6a6a72; }
      .tw-pane { flex: 1; padding: 0.6rem 0.85rem; font: 0.72rem/1.9 'JetBrains Mono Variable', monospace; overflow: hidden; }
      .tw-pane .tline { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); animation: rise 0.25s ease-out; }
      .jtoast {
        position: absolute; bottom: 1rem; left: 50%; transform: translateX(-50%) translateY(6px);
        background: rgb(198 255 26 / 0.14); color: var(--accent); border: 1px solid rgb(198 255 26 / 0.3);
        border-radius: 999px; padding: 0.28rem 0.9rem; font: 0.72rem 'JetBrains Mono Variable', monospace;
        opacity: 0; pointer-events: none; transition: opacity 0.2s, transform 0.2s; z-index: 8;
      }
      .jtoast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

      /* capability buttons */
      .caps { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; margin: 1.8rem auto 0; }
      .cap {
        display: flex; flex-direction: column; align-items: flex-start; gap: 0.1rem;
        background: var(--bg2); border: 1px solid var(--line); border-radius: 0.7rem;
        padding: 0.6rem 1rem; cursor: pointer; text-align: left; min-width: 158px;
        transition: border-color 0.15s, background 0.15s, transform 0.15s;
      }
      .cap:hover { border-color: rgb(198 255 26 / 0.45); transform: translateY(-2px); }
      .cap.on { border-color: var(--accent); background: #14140f; }
      .cap b { font-family: 'IBM Plex Mono', monospace; font-size: 0.92rem; color: var(--text); }
      .cap.on b { color: var(--accent); }
      .cap span { font-size: 0.72rem; color: var(--sub); }

      .ms-foot { margin-top: 1.9rem; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
      .ms-req { font-size: 0.8rem; color: var(--sub); }
      .ms-req a { color: var(--accent); }

      /* The island · one black element, top-anchored, that grows on open. */
      .island {
        position: absolute; top: 0; left: 50%; transform: translateX(-50%);
        width: 132px; height: 30px; background: #000;
        border: 0.5px solid rgb(255 255 255 / 0.08); border-top: 0;
        border-radius: 0 0 11px 11px; z-index: 20; overflow: hidden;
        transition: width 0.34s cubic-bezier(0.22, 1, 0.36, 1), height 0.34s cubic-bezier(0.22, 1, 0.36, 1);
        box-shadow: 0 12px 40px rgb(0 0 0 / 0.5);
      }
      /* Height is set from content by JS (sizeIsland) so the panel hugs each
         view · no dead space below the shorter approve card. */
      .island.open { width: 372px; border-radius: 0 0 22px 22px; }
      .ncamera {
        position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
        width: 7px; height: 7px; border-radius: 50%;
        background: #050505; box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.08); z-index: 5;
      }
      .island :is(.nmodel, .nproj, .nhead, .ncost, .nctx-n, .nopt, .ncard-q, .ncard-ctx, .fstat, .ftot-l) {
        font-family: 'Inter Variable', system-ui, sans-serif;
      }

      /* collapsed pill content · absolute so it never adds to the panel's
         measured height. */
      .ncollapsed {
        position: absolute; top: 0; left: 0; right: 0; z-index: 2;
        display: flex; align-items: center; justify-content: space-between;
        height: 30px; padding: 0 11px; opacity: 1; transition: opacity 0.12s;
      }
      .island.open .ncollapsed { opacity: 0; pointer-events: none; }
      .ncol-l { display: flex; align-items: center; gap: 5px; }
      .sumdot { width: 6px; height: 6px; border-radius: 50%; }
      .sumdot.blocked { background: var(--amber); animation: pulse 1s infinite; }
      .sumdot.working { background: var(--grn); animation: pulse 1.6s infinite; }
      .ncol-l b { font-size: 12px; font-weight: 600; color: #fff; }
      .ncol-r .ndisc { width: 16px; height: 16px; }

      /* expanded panel · in normal flow so its height drives the island. The
         top pad clears the notch bar; the bottom pad matches the real app. */
      .npanel {
        position: relative; padding: 34px 0 11px; opacity: 0;
        transition: opacity 0.2s 0.06s;
      }
      .island.open .npanel { opacity: 1; }
      .nview[hidden] { display: none; }

      .nhead {
        display: flex; align-items: center; gap: 6px; padding: 2px 16px 4px;
      }
      .nhead-t { font-size: 10px; font-weight: 700; letter-spacing: 1.6px; color: rgb(255 255 255 / 0.55); }
      .nhead b { font-size: 10px; font-weight: 600; color: rgb(255 255 255 / 0.55); }
      .ndot { width: 5px; height: 5px; border-radius: 50%; }
      .ndot.green { background: var(--accent); }
      .ndot.done { background: var(--done); }
      .ndot.idle { background: #7a7a82; }
      .nspacer { flex: 1; }

      .nrows { padding: 0 6px; }
      .nrow {
        display: flex; align-items: center; gap: 8px; width: 100%; padding: 5px 10px; border-radius: 7px;
        background: none; border: 0; text-align: left; cursor: pointer;
        transition: background 0.12s;
      }
      .nrow:hover { background: rgb(255 255 255 / 0.05); }
      .ndisc {
        width: 18px; height: 18px; flex-shrink: 0; color: #fff;
        display: flex; align-items: center; justify-content: center;
      }
      .ndisc svg { width: 100%; height: 100%; display: block; }
      .ndisc svg path { fill: currentColor; }
      .nmodel { font-size: 12px; font-weight: 600; color: #fff; white-space: nowrap; }
      .nproj { font-size: 11px; color: rgb(255 255 255 / 0.55); white-space: nowrap; }
      .nctx { display: flex; align-items: center; gap: 3px; }
      .nctx-bar { width: 26px; height: 3.5px; border-radius: 2px; background: rgb(255 255 255 / 0.12); overflow: hidden; }
      .nctx-bar i { display: block; height: 100%; border-radius: 2px; }
      .nctx-bar i.grn { background: var(--grn); }
      .nctx-bar i.amber { background: #ff9e0a; }
      .nctx-bar i.red { background: #f26b61; }
      .nctx-n { font-size: 8px; font-weight: 600; color: rgb(255 255 255 / 0.55); font-family: 'JetBrains Mono Variable', monospace; }
      .ncost { font-size: 10px; color: rgb(255 255 255 / 0.55); font-family: 'JetBrains Mono Variable', monospace; }
      .npill {
        font-size: 9px; font-weight: 600; padding: 2px 6px; border-radius: 999px; white-space: nowrap;
      }
      .npill.blocked { color: var(--amber); background: rgb(255 158 10 / 0.15); }
      .npill.working { color: var(--grn); background: rgb(198 255 26 / 0.15); }
      .npill.done { color: var(--done); background: rgb(48 209 89 / 0.15); }
      .npill.idle { color: #9a9aa2; background: rgb(154 154 162 / 0.13); }

      .nfoot {
        display: flex; align-items: center; gap: 12px; padding: 8px 16px 0;
      }
      .fstat { display: flex; align-items: center; gap: 4px; font-size: 10px; color: rgb(255 255 255 / 0.55); }
      .fstat b { color: #fff; font-weight: 600; }
      .ftotal { font-size: 10px; font-weight: 600; color: #fff; font-family: 'JetBrains Mono Variable', monospace; }
      .ftot-l { font-size: 9px; color: rgb(255 255 255 / 0.55); margin-left: 3px; }

      /* permission card · merged approve/answer view (real PermissionCardView) */
      #nview-approve { padding: 0 16px; }
      .ncard-head { display: flex; align-items: center; gap: 7px; padding-bottom: 8px; }
      .ncard-head b { font-size: 12px; font-weight: 600; color: #fff; }
      .ncard-hand { font-size: 12px; }
      .ncard-open { color: rgb(255 255 255 / 0.55); font-size: 12px; }
      .ncard-ctx { font-size: 10.5px; color: rgb(255 255 255 / 0.5); margin-bottom: 5px; }
      .ncard-q { font-size: 12.5px; font-weight: 600; color: #fff; line-height: 1.35; margin-bottom: 9px; }
      .ncard-q b { color: var(--accent); font-weight: 600; }
      .ncard-opts { display: flex; flex-direction: column; gap: 5px; }
      .nopt {
        display: flex; align-items: center; gap: 9px; width: 100%; text-align: left;
        padding: 7px 10px; border: 0; border-radius: 8px; cursor: pointer;
        background: rgb(255 255 255 / 0.06); color: #fff; font-size: 12px;
      }
      .nnum { font-family: 'JetBrains Mono Variable', monospace; font-size: 11px; font-weight: 700; width: 14px; color: rgb(255 255 255 / 0.55); }
      .nopt-l { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .nkey { font-size: 9px; color: rgb(255 255 255 / 0.5); }
      .nopt.allow { background: rgb(198 255 26 / 0.16); }
      .nopt.allow .nnum { color: var(--accent); }
      .nopt.allow:hover { background: rgb(198 255 26 / 0.26); }
      .nopt.deny { background: rgb(209 56 51 / 0.16); }
      .nopt.deny .nnum { color: #f26b61; }
      .nopt.deny:hover { background: rgb(209 56 51 / 0.26); }
      .nopt:not(.allow):not(.deny):hover { background: rgb(255 255 255 / 0.11); }

      /* Repo call to action */
      .cta-card {
        position: relative; overflow: hidden; text-align: center;
        max-width: 720px; margin: 0 auto;
        background: linear-gradient(180deg, #14141a, #0c0c11);
        border: 1px solid var(--line); border-radius: 1.4rem;
        padding: 3.2rem 2rem 2.8rem;
      }
      .cta-badge {
        display: inline-block; font: 0.72rem 'IBM Plex Mono', monospace; color: var(--accent);
        background: rgb(198 255 26 / 0.1); border: 1px solid rgb(198 255 26 / 0.25);
        padding: 0.3rem 0.85rem; border-radius: 999px; margin-bottom: 1.3rem;
      }
      .cta-card h2 { font-size: clamp(1.7rem, 4vw, 2.25rem); letter-spacing: -0.02em; margin: 0 0 0.9rem; }
      .cta-card p { color: var(--sub); max-width: 40rem; margin: 0 auto; font-size: 1.03rem; line-height: 1.62; }
      .cta-actions { display: flex; gap: 0.8rem; justify-content: center; flex-wrap: wrap; margin-top: 1.9rem; }
      .cta-actions .btn { display: inline-flex; align-items: center; gap: 0.55rem; padding: 0.72rem 1.5rem; font-size: 0.98rem; transition: border-color 0.15s, filter 0.15s, transform 0.15s; }
      .cta-actions .btn:hover { transform: translateY(-2px); }
      .cta-ic { width: 18px; height: 18px; flex-shrink: 0; }
      .cta-mini {
        display: flex; gap: 0.7rem; justify-content: center; align-items: center; flex-wrap: wrap;
        margin-top: 1.7rem; font-size: 0.85rem; color: var(--sub);
      }
      .cta-repo-path {
        font: 0.78rem 'JetBrains Mono Variable', monospace; color: var(--text);
        background: var(--bg2); border: 1px solid var(--line);
        padding: 0.2rem 0.6rem; border-radius: 0.4rem;
      }
      .cta-mini a { color: var(--sub); }
      .cta-mini a:hover { color: var(--accent); }
      .cta-mini .sep { color: #4a4a54; }

      footer { border-top: 1px solid var(--line); margin-top: 2rem; }
      .foot-inner {
        max-width: 1060px; margin: 0 auto; padding: 2rem 1.5rem;
        display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap;
      }
      .foot-brand { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; }
      .foot-brand .dim { font-weight: 400; font-size: 0.85rem; }
      .foot-links { display: flex; gap: 1.3rem; color: var(--sub); font-size: 0.92rem; }
      .foot-links a:hover { color: var(--accent); }

      @media (max-width: 900px) {
        .orch, .notch { grid-template-columns: 1fr; }
        section, header.hero { padding: 3rem 1.25rem; }
        .agent-grid { grid-template-columns: repeat(3, 1fr); }
      }
      @media (max-width: 480px) {
        .agent-grid { grid-template-columns: repeat(2, 1fr); }
        .nav-links a[href$='orchestration/'] { display: none; }
      }

      /* Four nav links + the GitHub pill no longer fit a phone in one row:
         let them wrap rather than widen the page. */
      @media (max-width: 560px) {
        .nav-inner { flex-wrap: wrap; row-gap: 0.45rem; padding-top: 0.7rem; padding-bottom: 0.7rem; }
        .nav-links { gap: 0.9rem; font-size: 0.78rem; flex-wrap: wrap; justify-content: flex-end; }
      }
    </style>
  </body>
</html>
